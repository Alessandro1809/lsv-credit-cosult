---
import HeroProductSwitcher from '../components/HeroProductSwitcher';
import Layout from '../layouts/Layout.astro';

const quickFacts = [
	{
		label: 'Límite orientativo',
		title: 'Monto máximo',
		text: 'Hasta ₡10.000.000, siempre que la capacidad de pago lo permita.',
	},
	{
		label: 'Estimación mensual',
		title: 'Cuota de referencia',
		text: '₡19.500 mensuales por cada millón, calculado a 10 años.',
	},
	{
		label: 'Modalidad',
		title: 'Tipo de crédito',
		text: 'Se manejan créditos personales.',
	},
	{
		label: 'Manejo de deuda',
		title: 'Flexibilidad',
		text: 'Podés realizar abonos extraordinarios.',
	},
];

const requirements = [
	'Mínimo 1 año laborando con el mismo patrono.',
	'Historial crediticio mínimo de 1 mes.',
	'Si tenés deudas activas, no debés estar moroso.',
	'Para medir la capacidad de pago se requiere el estudio de cuotas de la Caja.',
	'Se debe indicar el monto que deseás adquirir.',
];

const basicData = [
	'Cédula.',
	'Número de teléfono.',
	'Correo electrónico.',
	'Dirección exacta.',
];

const workData = [
	'Dónde trabajás.',
	'Nombre de la empresa.',
	'Desde hace cuánto tiempo laborás ahí.',
	'Nombre del puesto que desempeñás.',
];

const steps = [
	{
		title: 'Enviás tus datos',
		text: 'Compartís tu información básica, laboral y el monto que deseás solicitar.',
	},
	{
		title: 'Revisión inicial',
		text: 'Se valida si cumplís con los requisitos mínimos y se solicita la información necesaria para medir capacidad de pago.',
	},
	{
		title: 'Autorización SUGEF',
		text: 'Se firma la autorización emitida por SUGEF. Normalmente puede gestionarse mediante mensajero o de forma presencial.',
	},
	{
		title: 'Análisis del crédito',
		text: 'El proceso usual de análisis puede tomar de 2 a 3 semanas.',
	},
	{
		title: 'Firma de documentos',
		text: 'Si el crédito es aprobado, se procede con la firma de los documentos del contrato.',
	},
	{
		title: 'Depósito del dinero',
		text: 'Normalmente el dinero se deposita entre 2 y 3 días hábiles después de firmar los documentos del contrato.',
	},
];

const faqs = [
	{
		question: '¿Cuánto se paga por millón?',
		answer: 'Como referencia, ₡19.500 por mes por cada millón a un plazo de 10 años.',
	},
	{
		question: '¿Cuál es el monto máximo?',
		answer: 'Hasta ₡10 millones, sujeto a que la capacidad de pago lo permita.',
	},
	{
		question: '¿Puedo hacer abonos extraordinarios?',
		answer: 'Sí, se pueden realizar abonos extraordinarios.',
	},
	{
		question: '¿Cuánto tardan en responder?',
		answer: 'La respuesta inicial usualmente se brinda después de 1 día hábil.',
	},
	{
		question: '¿Cuánto tarda el proceso completo?',
		answer: 'El análisis del crédito puede tomar usualmente de 2 a 3 semanas.',
	},
	{
		question: '¿Cuándo depositan el dinero?',
		answer: 'Normalmente entre 2 y 3 días hábiles después de firmar los documentos del contrato.',
	},
];

const whatsappLink = 'https://wa.link/zvpsjg';
---

<Layout>
	<div class="site-shell">
		<div class="grain" aria-hidden="true"></div>
		<header class="floating-nav" data-nav>
			<a class="brand-mark" href="#inicio" aria-label="Ir al inicio">
				<img class="brand-logo" src="/bcr-logo-white.png" alt="BCR, Banco de Costa Rica" width="682" height="250" />
				<span class="brand-copy">Crédito asistido</span>
			</a>
			<nav class="nav-links" aria-label="Navegación principal">
				<a href="#contacto">Contacto</a>
				<a href="#resumen">Resumen</a>
				<a href="#requisitos">Requisitos</a>
				<a href="#proceso">Proceso</a>
				<a href="#faq">FAQ</a>
			</nav>
			<a class="nav-cta" href="#contacto">Consultar ahora</a>
			<button class="menu-button" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-button>
				<span></span>
				<span></span>
			</button>
		</header>

		<div class="menu-overlay" data-menu-overlay aria-hidden="true">
			<nav class="overlay-links" aria-label="Menú móvil">
				<a style="--delay: 100ms" href="#contacto">Contacto</a>
				<a style="--delay: 150ms" href="#resumen">Resumen del crédito</a>
				<a style="--delay: 200ms" href="#requisitos">Requisitos</a>
				<a style="--delay: 250ms" href="#datos">Datos necesarios</a>
				<a style="--delay: 300ms" href="#proceso">Proceso</a>
			</nav>
		</div>

		<main id="inicio">
			<HeroProductSwitcher client:load />

			<section class="section-pad contact-section" id="contacto">
				<div class="contact-copy reveal">
					<h2>Comencemos con la evaluación</h2>
					<p>Enviá tus datos para revisar tu caso y recibir orientación sobre el siguiente paso.</p>
					<div class="visible-contact">
						<a href="mailto:ashsevilla@bancobcr.com">ashsevilla@bancobcr.com</a>
						<span>Teléfono: 61031947</span>
					</div>
					<div class="contact-actions">
						<a class="button button-secondary" href={whatsappLink} target="_blank" rel="noopener noreferrer">
							<span>Consultar por WhatsApp</span>
							<span class="button-icon" aria-hidden="true">↗</span>
						</a>
						<a class="contact-qr" href={whatsappLink} target="_blank" rel="noopener noreferrer" aria-label="Abrir WhatsApp desde el código QR">
							<img src="/wa-link-zvpsjg.png" alt="Código QR para consultar por WhatsApp" width="260" height="260" loading="eager" decoding="async" />
							<span>Escanear QR</span>
						</a>
					</div>
				</div>
				<div class="bezel reveal delay-1 form-shell">
					<form class="core contact-form" action="mailto:ashsevilla@bancobcr.com" method="post" enctype="text/plain">
						<label>
							<span>Nombre completo</span>
							<input name="Nombre completo" autocomplete="name" required />
						</label>
						<label>
							<span>Cédula</span>
							<input name="Cédula" inputmode="numeric" required />
						</label>
						<label>
							<span>Teléfono</span>
							<input name="Teléfono" autocomplete="tel" inputmode="tel" required />
						</label>
						<label>
							<span>Correo</span>
							<input name="Correo" type="email" autocomplete="email" required />
						</label>
						<label class="wide">
							<span>Dirección exacta</span>
							<input name="Dirección exacta" autocomplete="street-address" required />
						</label>
						<label>
							<span>Empresa donde trabaja</span>
							<input name="Empresa donde trabaja" required />
						</label>
						<label>
							<span>Puesto</span>
							<input name="Puesto" required />
						</label>
						<label>
							<span>Antigüedad laboral</span>
							<input name="Antigüedad laboral" required />
						</label>
						<label>
							<span>Monto que desea solicitar</span>
							<input name="Monto que desea solicitar" inputmode="numeric" required />
						</label>
						<label>
							<span>¿Tiene deudas actualmente?</span>
							<select name="Tiene deudas actualmente" required>
								<option value="">Seleccionar</option>
								<option>Sí</option>
								<option>No</option>
							</select>
						</label>
						<label>
							<span>¿Está al día con sus pagos?</span>
							<select name="Está al día con sus pagos" required>
								<option value="">Seleccionar</option>
								<option>Sí</option>
								<option>No</option>
								<option>No aplica</option>
							</select>
						</label>
						<label class="wide">
							<span>Comentarios adicionales</span>
							<textarea name="Comentarios adicionales" rows="4"></textarea>
						</label>
						<button class="button button-primary wide" type="submit">
							<span>Enviar información</span>
							<span class="button-icon" aria-hidden="true">↗</span>
						</button>
					</form>
				</div>
			</section>

			<section class="section-pad quick-section" id="resumen">
				<div class="section-heading reveal">
					<h2>Lo esencial del crédito personal</h2>
				</div>
				<div class="quick-grid">
					{quickFacts.map((fact, index) => (
						<article class="quick-cell">
							<div class={`bezel reveal delay-${index % 3}`}>
								<div class="core fact-card">
								<span class="fact-number">{fact.label}</span>
								<h3>{fact.title}</h3>
								<p>{fact.text}</p>
								</div>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="section-pad qualification" id="requisitos">
				<div class="qualification-copy reveal">
					<h2>¿Qué necesitás para calificar?</h2>
					<p>
						Para iniciar una valoración se revisan datos laborales, comportamiento crediticio y capacidad de pago.
					</p>
				</div>
				<div class="qualification-layout">
					<div class="bezel reveal">
						<div class="core checklist-card">
							{requirements.map((item) => (
								<div class="check-row">
									<span aria-hidden="true"></span>
									<p>{item}</p>
								</div>
							))}
						</div>
					</div>
					<aside class="bezel reveal delay-1 requirement-callout">
						<div class="core callout-core">
							<span>Requisito indispensable</span>
							<strong>Indicar el monto que querés solicitar para iniciar correctamente la valoración.</strong>
						</div>
					</aside>
				</div>
			</section>

			<section class="section-pad data-section" id="datos">
				<div class="section-heading reveal">
					<h2>Información necesaria para iniciar</h2>
					<p>Tené estos datos a mano para agilizar la revisión.</p>
				</div>
				<div class="data-grid">
					<article class="bezel reveal">
						<div class="core data-card">
							<h3>Datos básicos</h3>
							<ul>{basicData.map((item) => <li>{item}</li>)}</ul>
						</div>
					</article>
					<article class="bezel reveal delay-1 data-card-offset">
						<div class="core data-card">
							<h3>Datos laborales</h3>
							<ul>{workData.map((item) => <li>{item}</li>)}</ul>
						</div>
					</article>
				</div>
				<div class="center-cta reveal">
					<a class="button button-primary" href="#contacto">
						<span>Enviar mis datos para revisión</span>
						<span class="button-icon" aria-hidden="true">↗</span>
					</a>
				</div>
			</section>

			<section class="section-pad process-section" id="proceso">
				<div class="section-heading reveal">
					<h2>¿Cómo funciona el proceso?</h2>
				</div>
				<div class="process-rail">
					{steps.map((step, index) => (
						<article class="process-step reveal" style={`--step:${index + 1}`}>
							<div class="step-index">0{index + 1}</div>
							<div>
								<h3>{step.title}</h3>
								<p>{step.text}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="section-pad card-section" id="tarjeta">
				<div class="bezel reveal credit-card-shell">
					<div class="core credit-card-core">
						<div>
							<h2>¿Interesado en una tarjeta de crédito?</h2>
							<p>
								Para solicitar una tarjeta de crédito, debés contar con al menos 6 meses de continuidad laboral con el mismo patrono.
							</p>
						</div>
						<ul>
							<li>Evaluación según perfil y capacidad de pago.</li>
							<li>Proceso guiado.</li>
							<li>Ideal para quienes desean iniciar o ampliar su relación crediticia.</li>
						</ul>
						<a class="button button-secondary dark-button" href={whatsappLink} target="_blank" rel="noopener noreferrer">
							<span>Consultar por tarjeta de crédito</span>
							<span class="button-icon" aria-hidden="true">↗</span>
						</a>
						<p class="note">
							El sitio oficial BCR presenta opciones de tarjetas de crédito, incluyendo alternativas digitales y tarjetas sin anualidad según producto. Validar condiciones vigentes antes de publicar.
						</p>
					</div>
				</div>
			</section>

			<section class="section-pad faq-section" id="faq">
				<div class="section-heading reveal">
					<h2>Preguntas frecuentes</h2>
				</div>
				<div class="faq-list reveal">
					{faqs.map((faq, index) => (
						<details class="faq-item" open={index === 0}>
							<summary>
								<span>{faq.question}</span>
								<i aria-hidden="true"></i>
							</summary>
							<p>{faq.answer}</p>
						</details>
					))}
				</div>
			</section>

			<section class="section-pad final-cta">
				<div class="bezel reveal">
					<div class="core final-core">
						<h2>Revisemos si podés avanzar con tu solicitud</h2>
						<p>
							Compartí tu información básica y recibí orientación sobre requisitos, capacidad de pago y próximos pasos para tu crédito personal o tarjeta de crédito.
						</p>
						<a class="button button-primary" href="#contacto">
							<span>Comenzar con mi evaluación</span>
							<span class="button-icon" aria-hidden="true">↗</span>
						</a>
					</div>
				</div>
			</section>
		</main>

		<footer class="legal-footer">
			<p>
				La información presentada es orientativa y está sujeta a validación. La aprobación del crédito, monto, plazo, cuota, requisitos finales y desembolso dependen del análisis crediticio, capacidad de pago, políticas internas, documentación presentada y normativa aplicable. Las condiciones pueden cambiar sin previo aviso.
			</p>
		</footer>
	</div>
</Layout>

<script>
	const nav = document.querySelector('[data-nav]');
	const menuButton = document.querySelector('[data-menu-button]');
	const menuOverlay = document.querySelector('[data-menu-overlay]');
	const menuLinks = menuOverlay?.querySelectorAll('a') ?? [];
	const internalLinks = document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	const setMenu = (open: boolean) => {
		nav?.classList.toggle('menu-open', open);
		menuOverlay?.classList.toggle('is-open', open);
		menuOverlay?.setAttribute('aria-hidden', String(!open));
		menuButton?.setAttribute('aria-expanded', String(open));
	};

	menuButton?.addEventListener('click', () => {
		setMenu(menuButton.getAttribute('aria-expanded') !== 'true');
	});

	menuLinks.forEach((link) => {
		link.addEventListener('click', () => setMenu(false));
	});

	const scrollToHash = (hash: string, updateHistory = true) => {
		const id = decodeURIComponent(hash.replace('#', ''));
		const target = document.getElementById(id);

		if (!target) return;

		const navHeight = nav?.getBoundingClientRect().height ?? 0;
		const top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - navHeight - 32);

		window.scrollTo({
			top,
			behavior: prefersReducedMotion.matches ? 'auto' : 'smooth',
		});

		if (updateHistory) {
			history.pushState(null, '', hash);
		}
	};

	internalLinks.forEach((link) => {
		link.addEventListener('click', (event) => {
			const hash = link.getAttribute('href');

			if (!hash || hash === '#') return;

			event.preventDefault();
			setMenu(false);
			scrollToHash(hash);
		});
	});

	if (location.hash) {
		requestAnimationFrame(() => scrollToHash(location.hash, false));
	}

	const revealTargets = document.querySelectorAll('.reveal');
	document.documentElement.classList.add('js-reveal');
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
	);

	revealTargets.forEach((target) => observer.observe(target));
</script>

<style>
	:global(body) {
		background:
			radial-gradient(circle at 9% 8%, rgb(var(--bcr-blue-rgb) / 0.16), transparent 30rem),
			radial-gradient(circle at 88% 16%, rgb(var(--bcr-red-rgb) / 0.1), transparent 22rem),
			linear-gradient(135deg, var(--paper) 0%, var(--paper-soft) 52%, var(--bcr-blue-soft) 100%);
		color: var(--ink);
	}

	.site-shell {
		position: relative;
		isolation: isolate;
		min-height: 100dvh;
	}

	.grain { display: none; }

	section[id] {
		scroll-margin-top: 116px;
	}

	.section-pad {
		width: min(100% - 48px, 1220px);
		margin: 0 auto;
		padding: 128px 0;
	}

	.floating-nav {
		position: fixed;
		top: 24px;
		left: 50%;
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 10px;
		width: min(calc(100% - 32px), 980px);
		min-height: 68px;
		padding: 8px;
		border-radius: 999px;
		border: 1px solid rgb(var(--bcr-blue-rgb) / 0.12);
		background: rgb(255 255 255 / 0.86);
		box-shadow: 0 8px 8px rgb(var(--bcr-blue-rgb) / 0.08), inset 0 1px 0 rgb(255 255 255 / 0.82);
		backdrop-filter: blur(22px) saturate(1.16);
		transform: translateX(-50%);
	}

	.brand-mark,
	.nav-links a,
	.nav-cta {
		text-decoration: none;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		min-width: max-content;
		padding: 6px 12px 6px 6px;
		border-radius: 999px;
		background: rgb(var(--bcr-blue-rgb) / 0.06);
	}

	.brand-logo {
		display: block;
		width: 116px;
		height: 42px;
		border-radius: 999px;
		background: var(--ink);
		object-fit: contain;
		object-position: center;
	}

	.brand-copy {
		font-size: 13px;
		font-weight: 720;
		letter-spacing: -0.02em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2px;
		flex: 1;
	}

	.nav-links a {
		padding: 12px 13px;
		border-radius: 999px;
		color: rgb(17 24 39 / 0.82);
		font-size: 13px;
		font-weight: 650;
		transition: color 620ms cubic-bezier(0.32, 0.72, 0, 1), background 620ms cubic-bezier(0.32, 0.72, 0, 1), transform 620ms cubic-bezier(0.32, 0.72, 0, 1);
	}

	.nav-links a:hover {
		background: rgb(var(--bcr-blue-rgb) / 0.09);
		color: var(--bcr-blue);
		transform: translateY(-1px);
	}

	.nav-cta {
		min-width: max-content;
		padding: 14px 18px;
		border-radius: 999px;
		background: var(--bcr-red);
		color: var(--paper);
		font-size: 13px;
		font-weight: 760;
		transition: transform 620ms cubic-bezier(0.32, 0.72, 0, 1), background 620ms cubic-bezier(0.32, 0.72, 0, 1);
	}

	.nav-cta:hover {
		background: var(--bcr-red-deep);
		transform: translateY(-1px) scale(1.015);
	}

	.menu-button {
		display: none;
		position: relative;
		width: 48px;
		height: 48px;
		border: 0;
		border-radius: 50%;
		background: var(--bcr-blue);
		color: var(--paper);
		cursor: pointer;
	}

	.menu-button span {
		position: absolute;
		left: 14px;
		width: 20px;
		height: 1px;
		background: currentColor;
		transition: transform 720ms cubic-bezier(0.32, 0.72, 0, 1);
	}

	.menu-button span:first-child {
		transform: translateY(-4px);
	}

	.menu-button span:last-child {
		transform: translateY(4px);
	}

	.menu-open .menu-button span:first-child {
		transform: rotate(45deg);
	}

	.menu-open .menu-button span:last-child {
		transform: rotate(-45deg);
	}

	.menu-overlay {
		position: fixed;
		inset: 0;
		z-index: 2;
		display: grid;
		place-items: center;
		padding: 110px 24px 32px;
		background: rgb(246 248 252 / 0.92);
		backdrop-filter: blur(24px) saturate(1.18);
		opacity: 0;
		pointer-events: none;
		transform: scale(0.98);
		transition: opacity 760ms cubic-bezier(0.32, 0.72, 0, 1), transform 760ms cubic-bezier(0.32, 0.72, 0, 1);
	}

	.menu-overlay.is-open {
		opacity: 1;
		pointer-events: auto;
		transform: scale(1);
	}

	.overlay-links {
		display: grid;
		gap: 16px;
		text-align: center;
	}

	.overlay-links a {
		color: var(--bcr-blue);
		font-size: clamp(2.1rem, 8vw, 5rem);
		font-weight: 760;
		letter-spacing: -0.035em;
		line-height: 0.95;
		text-decoration: none;
		opacity: 0;
		transform: translateY(48px);
		transition: opacity 760ms cubic-bezier(0.32, 0.72, 0, 1), transform 760ms cubic-bezier(0.32, 0.72, 0, 1);
		transition-delay: 0ms;
	}

	.menu-overlay.is-open .overlay-links a {
		opacity: 1;
		transform: translateY(0);
		transition-delay: var(--delay);
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	h1,
	h2 {
		max-width: 820px;
		font-weight: 780;
		letter-spacing: -0.035em;
		line-height: 0.98;
		text-wrap: balance;
	}

	h1 {
		font-size: clamp(3.1rem, 7vw, 6rem);
	}

	h2 {
		font-size: clamp(2.45rem, 5.2vw, 5.6rem);
	}

	h3 {
		font-size: 1.24rem;
		letter-spacing: -0.04em;
		line-height: 1.05;
	}

	.section-heading p,
